<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox spacing="10" alignment="CENTER" prefWidth="600" prefHeight="400"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.javafxapp.FavoritesController">
    <Label text="Избранные документы" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <ListView fx:id="listView" VBox.vgrow="ALWAYS"/>
    <HBox spacing="10" alignment="CENTER">
        <Button text="Открыть" onAction="#openSelected"/>
        <Button text="Удалить" onAction="#deleteSelected"/>
        <Button text="Закрыть" onAction="#closeWindow"/>
    </HBox>
</VBox>
