<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import java.net.URL?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.javafxapp.EditorController"
      alignment="CENTER" spacing="10" style="-fx-background-color: #ffffff;">
    <stylesheets>
        <URL value="@/style.css"/>
    </stylesheets>
    <padding>
        <Insets top="20" right="10" bottom="10" left="10"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
        <Button text="←" style="-fx-background-color: transparent; -fx-font-size: 20px;" onAction="#handleBack"/>
        <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </HBox>

    <VBox fx:id="subscriptionInfo" style="-fx-background-color: #f9f9f9; -fx-border-radius: 10; -fx-padding: 10;">
        <Label fx:id="subscriptionLabel" style="-fx-font-weight: bold;"/>
        <Label fx:id="daysRemainingLabel" style="-fx-text-fill: #666666;"/>
    </VBox>

    <TextArea fx:id="textArea" style="-fx-pref-width: 370px; -fx-pref-height: 500px; -fx-border-radius: 10;"/>

    <VBox fx:id="premiumFeatures" alignment="CENTER" spacing="10" style="-fx-padding: 10 0;">
        <Button text="Insert Image" style="-fx-background-color: #4a7dff; -fx-text-fill: white; -fx-pref-width: 200px; -fx-background-radius: 20;"
                onAction="#handleInsertImage"/>
        <Button text="Change Font" style="-fx-background-color: #4a7dff; -fx-text-fill: white; -fx-pref-width: 200px; -fx-background-radius: 20;"
                onAction="#handleChangeFont"/>
    </VBox>


    <Button fx:id="subscribeButton" text="Upgrade Plan"
            style="-fx-background-color: #ff6b00; -fx-text-fill: white; -fx-pref-width: 280px; -fx-pref-height: 40px; -fx-background-radius: 20; -fx-font-weight: bold;"
            onAction="#handleUpgrade"/>


    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0;">
        <Button fx:id="saveButton" text="Save"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                onAction="#handleSave"/>

        <Button fx:id="formatButton" text="Format Text"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;"
                onAction="#handleFormat"/>

        <Button fx:id="upgradeButton" text="Upgrade"
                style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                onAction="#handleUpgrade" visible="false"/>
    </HBox>
</VBox>
