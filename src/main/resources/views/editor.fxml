<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.web.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxapp.EditorController"
            prefWidth="1000" prefHeight="800">

    <center>
        <StackPane>
            <!-- Монитор (центрируется автоматически) -->
            <VBox alignment="CENTER" spacing="0">
                <!-- Верхняя часть монитора -->
                <StackPane>
                    <Rectangle width="900" height="750"
                               fill="#808080"
                               arcWidth="40" arcHeight="40"/>
                    <Rectangle width="850" height="700"
                               fill="#000000"
                               arcWidth="30" arcHeight="30"/>
                    <Rectangle width="830" height="680"
                               fill="#a8d8ea"
                               arcWidth="25" arcHeight="25"/>
                </StackPane>

                <!-- Основание монитора -->
                <VBox alignment="CENTER" spacing="0">
                    <Rectangle width="300" height="30"
                               fill="#808080"
                               arcWidth="15" arcHeight="15"/>
                    <Rectangle width="350" height="15"
                               fill="#666666"
                               arcWidth="10" arcHeight="10"/>
                </VBox>
            </VBox>

            <!-- КОНТЕНТ (поверх монитора) -->
            <VBox maxWidth="780" maxHeight="640"
                  spacing="15"
                  style="-fx-background-color: transparent;">

                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <!-- Заголовок -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button text="←"
                            style="-fx-background-color: transparent; -fx-font-size: 24px;"
                            onAction="#handleBack"/>
                    <Label fx:id="titleLabel"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Информация о подписке -->
                <VBox fx:id="subscriptionInfo"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 15; -fx-padding: 15;">
                    <Label fx:id="subscriptionLabel"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="daysRemainingLabel"
                           style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                </VBox>

                <!-- WebView -->
                <WebView fx:id="webView"
                         VBox.vgrow="ALWAYS"
                         style="-fx-background-color: #ffffff; -fx-background-radius: 15;"/>

                <!-- Премиум функции -->
                <VBox fx:id="premiumFeatures"
                      alignment="CENTER"
                      spacing="15"
                      style="-fx-background-color: #f5f5f5; -fx-background-radius: 20; -fx-padding: 20;">

                    <HBox spacing="20" alignment="CENTER">
                        <Button fx:id="insertImageButton"
                                text="Вставка изображения"
                                prefWidth="200" prefHeight="45"
                                style="-fx-background-color: #4a7dff; -fx-text-fill: white; -fx-background-radius: 22;"
                                onAction="#handleInsertImage"/>

                        <Button fx:id="changeFontButton"
                                text="Смена шрифта"
                                prefWidth="200" prefHeight="45"
                                style="-fx-background-color: #4a7dff; -fx-text-fill: white; -fx-background-radius: 22;"
                                onAction="#handleChangeFont"/>
                    </HBox>
                </VBox>

                <!-- Кнопки управления -->
                <HBox alignment="CENTER" spacing="15">
                    <Button fx:id="subscribeButton"
                            text="Сменить план"
                            prefWidth="200" prefHeight="45"
                            style="-fx-background-color: #ff6b00; -fx-text-fill: white; -fx-background-radius: 22; -fx-font-weight: bold;"
                            onAction="#handleUpgrade"/>

                    <Button fx:id="formatButton"
                            text="Формат"
                            prefWidth="150" prefHeight="45"
                            style="-fx-background-color: #4a7dff; -fx-text-fill: white; -fx-background-radius: 22;"
                            onAction="#handleFormat"/>
                </HBox>

                <!-- Нижние кнопки -->
                <HBox alignment="CENTER" spacing="15">
                    <Button fx:id="saveButton"
                            text="Сохранить"
                            prefWidth="130" prefHeight="40"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 20;"
                            onAction="#handleSave"/>

                    <Button fx:id="upgradeButton"
                            text="Смена плана"
                            prefWidth="130" prefHeight="40"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 20;"
                            onAction="#handleUpgrade"
                            visible="false"/>

                    <Button fx:id="cancelSubscriptionBtn"
                            text="Отменить подписку"
                            prefWidth="170" prefHeight="40"
                            style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;"
                            onAction="#handleCancelSubscription"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>