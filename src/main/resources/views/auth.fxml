<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<?import javafx.scene.Group?>
<Group xmlns="http://javafx.com/javafx/17"
       xmlns:fx="http://javafx.com/fxml/1"
       fx:controller="com.example.javafxapp.AuthController">


    <Rectangle width="550" height="700"
               fill="#c0c0c0"
               arcWidth="30" arcHeight="30"
               layoutX="25" layoutY="25"/>

    <Rectangle width="550" height="700"
               fill="#808080"
               arcWidth="30" arcHeight="30"
               layoutX="20" layoutY="20"/>

    <Rectangle width="510" height="640"
               fill="#000000"
               arcWidth="20" arcHeight="20"
               layoutX="40" layoutY="50"/>

    <Rectangle width="490" height="600"
               fill="#a8d8ea"
               arcWidth="20" arcHeight="20"
               layoutX="50" layoutY="70"/>

    <VBox layoutX="70" layoutY="90"
          prefWidth="450" prefHeight="560"
          alignment="TOP_CENTER" spacing="25">

        <Label text="Text Editor"
               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>

        <Label text="With Subscription"
               style="-fx-font-size: 18px; -fx-text-fill: #ffffff;"/>

        <TextField fx:id="usernameField"
                   promptText="Логин"
                   prefWidth="380" prefHeight="50"
                   style="-fx-background-color: #ffffff; -fx-text-fill: #000000; -fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 25;"/>

        <PasswordField fx:id="passwordField"
                       promptText="Пароль"
                       prefWidth="380" prefHeight="50"
                       style="-fx-background-color: #ffffff; -fx-text-fill: #000000; -fx-font-size: 16px; -fx-padding: 10 20; -fx-background-radius: 25;"/>

        <Button fx:id="loginButton"
                text="Войти"
                prefWidth="380" prefHeight="55"
                onAction="#handleLogin"
                style="-fx-background-color: #4ecdc4; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 27;"/>

        <Button fx:id="registerButton"
                text="Зарегистрироваться"
                prefWidth="380" prefHeight="45"
                onAction="#handleRegister"
                style="-fx-background-color: transparent; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-border-color: #ffffff; -fx-border-width: 2; -fx-border-radius: 22;"/>

        <Label fx:id="errorLabel"
               style="-fx-text-fill: #ff6b6b; -fx-font-size: 14px; -fx-font-weight: bold;" />

    </VBox>

    <Rectangle width="300" height="30"
               fill="#808080"
               layoutX="135" layoutY="720"/>

</Group>