<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.javafxapp.PaymentController"
      alignment="CENTER"
      spacing="20"
      prefWidth="600"
      prefHeight="700"
      style="-fx-background-color: linear-gradient(to bottom right, #e8f5e8, #f5e8f0, #f5dde8, #e0f0e0);">

    <stylesheets>
        <URL value="@/style.css"/>
    </stylesheets>

    <effect>
        <Glow level="0.05"/>
    </effect>

    <padding>
        <Insets top="40" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER" spacing="10">
        <Circle radius="8" fill="#ffb3c6"/>
        <Circle radius="8" fill="#c4e0c4"/>
        <Circle radius="8" fill="#ff99cc"/>
    </HBox>

    <Label text="🌸 Оформление подписки"
           style="-fx-font-size: 32px; -fx-font-weight: bold;
                  -fx-text-fill: #7a4d4d;
                  -fx-font-family: 'Segoe UI Light', 'Helvetica Neue', sans-serif;
                  -fx-effect: dropshadow(gaussian, #ffb3c6, 20, 0.3, 2, 3);"/>

    <VBox style="-fx-background-color: rgba(255,255,255,0.4);
                  -fx-background-radius: 25;
                  -fx-border-color: #ffb3c6;
                  -fx-border-radius: 25;
                  -fx-border-width: 2;
                  -fx-padding: 25;
                  -fx-spacing: 15;
                  -fx-effect: dropshadow(gaussian, rgba(255,179,198,0.3), 15, 0.3, 0, 3);"
          alignment="CENTER_LEFT"
          prefWidth="400">

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="🌿" style="-fx-font-size: 24px;"/>
            <Label text="План:" style="-fx-font-weight: bold; -fx-text-fill: #4d2e2e; -fx-font-size: 18px;"/>
        </HBox>
        <Label fx:id="planLabel"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #b3668c; -fx-padding: 0 0 0 40;"/>

        <Separator prefWidth="350" style="-fx-background-color: #c4e0c4; -fx-padding: 5 0;"/>

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="✨" style="-fx-font-size: 20px;"/>
            <Label text="Функции:" style="-fx-font-weight: bold; -fx-text-fill: #4d2e2e; -fx-font-size: 16px;"/>
        </HBox>
        <Label fx:id="descriptionLabel"
               style="-fx-font-size: 15px; -fx-text-fill: #6b8e6b; -fx-padding: 0 0 0 40;"
               wrapText="true"
               maxWidth="Infinity"
               prefWidth="0"
               minHeight="-Infinity"
               VBox.vgrow="ALWAYS"
               HBox.hgrow="ALWAYS" />

        <Separator prefWidth="350" style="-fx-background-color: #ffb3c6; -fx-padding: 5 0;"/>

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="💰" style="-fx-font-size: 22px;"/>
            <Label text="Стоимость:" style="-fx-font-weight: bold; -fx-text-fill: #4d2e2e; -fx-font-size: 18px;"/>
        </HBox>
        <Label fx:id="priceLabel"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #b3668c; -fx-padding: 0 0 0 40;"/>
    </VBox>

    <VBox spacing="15" alignment="CENTER_LEFT"
          style="-fx-background-color: rgba(255,255,255,0.3);
                 -fx-background-radius: 20;
                 -fx-border-color: #c4e0c4;
                 -fx-border-radius: 20;
                 -fx-border-width: 1.5;
                 -fx-padding: 25;"
          prefWidth="400">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="💳" style="-fx-font-size: 24px;"/>
            <Label text="Реквизиты карты"
                   style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #7a4d4d;"/>
        </HBox>

        <TextField fx:id="cardNumberField"
                   promptText="Номер карты"
                   prefWidth="350"
                   prefHeight="50"
                   style="-fx-background-color: rgba(255,255,255,0.7);
                          -fx-background-radius: 15;
                          -fx-border-color: #ffb3c6;
                          -fx-border-radius: 15;
                          -fx-border-width: 1.5;
                          -fx-font-size: 16px;
                          -fx-padding: 10 20;
                          -fx-text-fill: #b3668c;
                          -fx-prompt-text-fill: #b3868c;"/>

        <HBox spacing="15">
            <TextField fx:id="expiryDateField"
                       promptText="MM/ГГ"
                       prefWidth="150"
                       prefHeight="50"
                       style="-fx-background-color: rgba(255,255,255,0.7);
                              -fx-background-radius: 15;
                              -fx-border-color: #c4e0c4;
                              -fx-border-radius: 15;
                              -fx-border-width: 1.5;
                              -fx-font-size: 16px;
                              -fx-padding: 10 20;
                              -fx-text-fill: #6b8e6b;
                              -fx-prompt-text-fill: #7a9e7a;"/>

            <TextField fx:id="cvvField"
                       promptText="CVV"
                       prefWidth="100"
                       prefHeight="50"
                       style="-fx-background-color: rgba(255,255,255,0.7);
                              -fx-background-radius: 15;
                              -fx-border-color: #ffb3c6;
                              -fx-border-radius: 15;
                              -fx-border-width: 1.5;
                              -fx-font-size: 16px;
                              -fx-padding: 10 20;
                              -fx-text-fill: #b3668c;
                              -fx-prompt-text-fill: #b3868c;"/>
        </HBox>
    </VBox>

    <HBox alignment="CENTER" spacing="30" prefWidth="400">
        <VBox alignment="CENTER" spacing="5">
            <Label text="Сумма к оплате:"
                   style="-fx-font-size: 16px; -fx-text-fill: #4d2e2e; -fx-font-weight: bold;"/>
            <Label fx:id="totalLabel"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #b3668c;
                          -fx-effect: dropshadow(gaussian, #ffb3c6, 15, 0.3, 0, 2);"/>
        </VBox>
    </HBox>

    <Button fx:id="payButton"
            text="🌸 Оплатить"
            prefWidth="350"
            prefHeight="55"
            style="-fx-background-color: linear-gradient(to right, #ffb3c6, #ff99cc);
                   -fx-background-radius: 25;
                   -fx-border-color: white;
                   -fx-border-radius: 25;
                   -fx-border-width: 2;
                   -fx-text-fill: #4d2e2e;
                   -fx-font-size: 22px;
                   -fx-font-weight: bold;
                   -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, rgba(255,179,198,0.5), 15, 0.4, 0, 3);"
            onAction="#handlePayment"/>

    <Button text="← Вернуться назад"
            style="-fx-background-color: transparent;
                   -fx-text-fill: #6b8e6b;
                   -fx-font-size: 18px;
                   -fx-font-weight: bold;
                   -fx-padding: 15 0 5 0;
                   -fx-cursor: hand;"
            onAction="#handleBack"/>

    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
        <Circle radius="4" fill="#ffb3c6"/>
        <Circle radius="4" fill="#c4e0c4"/>
        <Circle radius="4" fill="#ff99cc"/>
    </HBox>
</VBox>